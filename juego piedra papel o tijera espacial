#  PANTALLA DE LOGIN / GESTION DE PERFILES
# ══════════════════════════════════════════════════════════════
class PantallaLogin(tk.Frame):

    def __init__(self, master, on_login):
        super().__init__(master, bg=PALETA["bg"])
        self.on_login = on_login
        self.perfiles = cargar_perfiles()
        FondoEstelar(self, master.W, master.H).place(x=0, y=0)
        self._caja = tk.Frame(self, bg=PALETA["bg"])
        self._caja.place(relx=0.5, rely=0.5, anchor="center")
        self._vista_lista()

    def _limpiar(self):
        for w in self._caja.winfo_children():
            w.destroy()

    # ── Vista lista ──────────────────────────────────────────
    def _vista_lista(self):
        self._limpiar()
        C = PALETA
        mk_label(self._caja, "◈  SELECCIONA PILOTO  ◈",
                 C["accent"], FUENTES["titulo"]).pack(pady=(0, 4))
        mk_label(self._caja, "o crea uno nuevo",
                 C["text2"], FUENTES["small"]).pack(pady=(0, 16))

        if self.perfiles:
            for nombre, datos in self.perfiles.items():
                self._tarjeta(nombre, datos)
        else:
            mk_label(self._caja, "Sin perfiles aun. iCrea el primero!",
                     C["text2"], FUENTES["medium"]).pack(pady=10)

        mk_sep(self._caja, C["accent"]).pack(fill="x", pady=14)
        mk_btn(self._caja, "+ CREAR NUEVO PERFIL", C["accent2"], C["bg"],
               self._vista_crear, px=10, py=7).pack(pady=4, ipadx=8, ipady=4)

    def _tarjeta(self, nombre: str, datos: dict):
        C     = PALETA
        wins  = datos.get("wins", 0)
        games = datos.get("games", 0)

        card = tk.Frame(self._caja, bg=C["card"], padx=12, pady=8, cursor="hand2")
        card.pack(fill="x", pady=3, ipadx=6)
        tk.Frame(card, bg=C["accent"], width=3).pack(side="left", fill="y", padx=(0, 10))

        info = tk.Frame(card, bg=C["card"])
        info.pack(side="left", expand=True, fill="x")

        top = tk.Frame(info, bg=C["card"])
        top.pack(fill="x")
        mk_label(top, datos.get("avatar", "🚀"), C["text"],
                 ("Segoe UI Emoji", 20)).pack(side="left", padx=(0, 6))
        mk_label(top, nombre, C["gold"], FUENTES["bold"]).pack(side="left")
        mk_label(top,
                 f"  {datos.get('edad','?')} anos . {datos.get('genero','-')}",
                 C["text2"], FUENTES["small"]).pack(side="left")
        mk_label(info,
                 f"Partidas: {games}  Victorias: {wins}  Win rate: {win_rate(wins, games)}",
                 C["teal"], FUENTES["small"]).pack(anchor="w")

        acc = tk.Frame(card, bg=C["card"])
        acc.pack(side="right")
        mk_btn(acc, "JUGAR",  C["accent2"], C["bg"],
               lambda n=nombre: self.on_login(n, self.perfiles[n]),
               px=10, py=4).pack(side="left", padx=3)
        mk_btn(acc, "EDITAR", C["card2"], C["text2"],
               lambda n=nombre: self._vista_editar(n),
               px=8, py=4).pack(side="left", padx=3)
        mk_btn(acc, "X", C["card2"], C["lose"],
               lambda n=nombre: self._eliminar(n),
               px=6, py=4).pack(side="left", padx=3)

        card.bind("<Enter>", lambda _, c=card: c.configure(bg=C["card2"]))
        card.bind("<Leave>", lambda _, c=card: c.configure(bg=C["card"]))

    def _eliminar(self, nombre: str):
        if messagebox.askyesno("Eliminar", f"Eliminar el perfil de {nombre}?"):
            del self.perfiles[nombre]
            guardar_perfiles(self.perfiles)
            self._vista_lista()

    # ── Formulario crear/editar ──────────────────────────────
    def _vista_crear(self):
        self._vista_form(None)

    def _vista_editar(self, nombre: str):
        self._vista_form(nombre)

    def _vista_form(self, nombre_edit):
        self._limpiar()
        C      = PALETA
        titulo = "EDITAR PERFIL" if nombre_edit else "CREAR PERFIL"
        mk_label(self._caja, f"o  {titulo}  o",
                 C["accent"], FUENTES["titulo"]).pack(pady=(0, 14))

        datos      = self.perfiles.get(nombre_edit, {}) if nombre_edit else {}
        self._form = FormPerfil(self._caja, datos)
        self._form.pack()

        mk_sep(self._caja, C["accent"]).pack(fill="x", pady=12)
        btns = tk.Frame(self._caja, bg=C["bg"])
        btns.pack()
        mk_btn(btns, "GUARDAR",  C["accent2"], C["bg"],
               lambda: self._guardar(nombre_edit), px=16, py=7).pack(side="left", padx=6)
        mk_btn(btns, "CANCELAR", C["card"], C["text2"],
               self._vista_lista, px=16, py=7).pack(side="left", padx=6)

    def _guardar(self, nombre_edit):
        datos = self._form.obtener()
        if datos is None:
            return
        nombre = datos["nombre"]
        if nombre in self.perfiles and nombre != nombre_edit:
            messagebox.showerror("Error", f"Ya existe un perfil llamado '{nombre}'.")
            return
        # Preservar estadisticas al editar
        if nombre_edit and nombre_edit in self.perfiles:
            viejo        = self.perfiles.pop(nombre_edit)
            datos["wins"]  = viejo.get("wins", 0)
            datos["games"] = viejo.get("games", 0)
        else:
            datos["wins"] = datos["games"] = 0
        self.perfiles[nombre] = datos
        guardar_perfiles(self.perfiles)
        self._vista_lista()


