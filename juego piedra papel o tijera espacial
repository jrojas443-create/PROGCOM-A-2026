#  FORMULARIO DE PERFIL (reutilizable)
# ══════════════════════════════════════════════════════════════
GENEROS = ["Masculino", "Femenino", "No binario", "Prefiero no decir"]


class FormPerfil(tk.Frame):
    """Widget de formulario para crear/editar un perfil."""

    def __init__(self, parent, datos=None):
        super().__init__(parent, bg=PALETA["bg"])
        C     = PALETA
        datos = datos or {}
        self._av_var  = tk.StringVar(value=datos.get("avatar", AVATARES[0]))
        self._gen_var = tk.StringVar(value=datos.get("genero", GENEROS[-1]))
        self._av_btns = {}

        # Avatar
        mk_label(self, "Avatar:", C["text2"], FUENTES["small"]).pack(anchor="w")
        grid = tk.Frame(self, bg=C["bg"])
        grid.pack(pady=(2, 10))
        for i, av in enumerate(AVATARES):
            b = tk.Button(grid, text=av, bg=C["card"], fg=C["text"],
                          font=("Segoe UI Emoji", 17), relief="flat", bd=0,
                          padx=5, pady=3, cursor="hand2",
                          command=lambda a=av: self._sel_avatar(a))
            b.grid(row=i // 6, column=i % 6, padx=2, pady=2)
            self._av_btns[av] = b
        self._sel_avatar(self._av_var.get())

        # Campos
        campos = tk.Frame(self, bg=C["bg"])
        campos.pack(fill="x")

        def campo(label, row, valor="") -> tk.Entry:
            mk_label(campos, label, C["text2"], FUENTES["small"]).grid(
                row=row, column=0, sticky="w", pady=5, padx=(0, 10))
            e = tk.Entry(campos, width=22, bg=C["card"], fg=C["text"],
                         insertbackground=C["accent"], relief="flat",
                         font=FUENTES["normal"])
            e.insert(0, valor)
            e.grid(row=row, column=1, sticky="w")
            return e

        self._e_nombre = campo("Nombre:", 0, datos.get("nombre", ""))
        self._e_edad   = campo("Edad:",   1, str(datos.get("edad", "")))

        # Genero
        mk_label(campos, "Genero:", C["text2"], FUENTES["small"]).grid(
            row=2, column=0, sticky="w", pady=5, padx=(0, 10))
        gf = tk.Frame(campos, bg=C["bg"])
        gf.grid(row=2, column=1, sticky="w")
        for g in GENEROS:
            tk.Radiobutton(gf, text=g, variable=self._gen_var, value=g,
                           bg=C["bg"], fg=C["text"], selectcolor=C["card"],
                           activebackground=C["bg"], font=FUENTES["small"],
                           cursor="hand2").pack(side="left", padx=3)

    def _sel_avatar(self, av: str) -> None:
        self._av_var.set(av)
        for a, b in self._av_btns.items():
            b.configure(bg=PALETA["accent2"] if a == av else PALETA["card"])

    def obtener(self) -> dict:
        """Valida y devuelve los datos, o None si hay error."""
        nombre = self._e_nombre.get().strip()
        edad_s = self._e_edad.get().strip()
        if not nombre:
            messagebox.showerror("Error", "El nombre no puede estar vacio.")
            return None
        if not edad_s.isdigit() or not (1 <= int(edad_s) <= 120):
            messagebox.showerror("Error", "Edad invalida (1-120).")
            return None
        return {
            "nombre": nombre,
            "edad":   int(edad_s),
            "genero": self._gen_var.get(),
            "avatar": self._av_var.get(),
        }


