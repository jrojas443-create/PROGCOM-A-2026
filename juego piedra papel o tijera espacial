def mk_label(parent, texto, fg, fuente, wrap=0) -> tk.Label:
    lbl = tk.Label(parent, text=texto, bg=parent["bg"], fg=fg, font=fuente)
    if wrap:
        lbl.configure(wraplength=wrap, justify="left")
    return lbl


def mk_btn(parent, texto, bg, fg, cmd, px=12, py=6) -> tk.Button:
    b = tk.Button(
        parent, text=texto, bg=bg, fg=fg,
        font=FUENTES["bold"], relief="flat", bd=0,
        padx=px, pady=py, cursor="hand2",
        activebackground=PALETA["btn_h"], activeforeground=PALETA["bg"],
        command=cmd,
    )
    b.bind("<Enter>", lambda _: b.configure(bg=PALETA["btn_h"], fg=PALETA["bg"]))
    b.bind("<Leave>", lambda _: b.configure(bg=bg, fg=fg))
    return b


def mk_sep(parent, color="#00d4ff", height=1) -> tk.Frame:
    return tk.Frame(parent, bg=color, height=height)


# ══════════════════════════════════════════════════════════════
#  FONDO ESTELAR ANIMADO
# ══════════════════════════════════════════════════════════════
STAR_COLORS = ["#ffffff", "#d0e8ff", "#a0c4ff", "#00d4ff", "#7b5ea7", "#00ffcc"]
SHIP_EMOJIS = ["🚀", "🛸", "🛰️"]


class FondoEstelar(tk.Canvas):
    """Campo de estrellas parpadeantes con naves moviendose."""

    def __init__(self, parent, w: int, h: int):
        super().__init__(parent, width=w, height=h,
                         bg=PALETA["bg"], highlightthickness=0)
        self.w, self.h = w, h
        self._frame = 0
        self._estrellas = []
        self._naves = []
        self._crear_estrellas(130)
        self._crear_naves(5)
        self._tick()

    def _crear_estrellas(self, n: int) -> None:
        for _ in range(n):
            x     = random.uniform(0, self.w)
            y     = random.uniform(0, self.h)
            fase  = random.uniform(0, 2 * math.pi)
            vel   = random.uniform(0.015, 0.05)
            color = random.choice(STAR_COLORS)
            size  = random.choices([1, 2, 3], weights=[6, 3, 1])[0]
            if size < 3:
                d   = size + 1
                cid = self.create_oval(x, y, x + d, y + d, fill=color, outline="")
            else:
                cid = self.create_text(x, y, text="✦", fill=color,
                                       font=("Consolas", random.choice([8, 9, 10])))
            self._estrellas.append({"cid": cid, "color": color,
                                    "fase": fase, "vel": vel})

    def _crear_naves(self, n: int) -> None:
        for _ in range(n):
            x   = random.uniform(20, self.w - 20)
            y   = random.uniform(20, self.h - 20)
            vx  = random.choice([-1, 1]) * random.uniform(0.5, 1.3)
            vy  = random.choice([-1, 1]) * random.uniform(0.3, 0.9)
            cid = self.create_text(x, y, text=random.choice(SHIP_EMOJIS),
                                   font=("Segoe UI Emoji", 15), tags="nave")
            self._naves.append({"cid": cid, "x": x, "y": y, "vx": vx, "vy": vy})

    def _tick(self) -> None:
        f = self._frame = self._frame + 1

        for s in self._estrellas:
            v = (math.sin(f * s["vel"] + s["fase"]) + 1) / 2
            r, g, b = (int(s["color"][i:i + 2], 16) for i in (1, 3, 5))
            k   = 0.25 + 0.75 * v
            col = f"#{int(r*k):02x}{int(g*k):02x}{int(b*k):02x}"
            try:
                self.itemconfig(s["cid"], fill=col)
            except tk.TclError:
                pass

        for nav in self._naves:
            nav["vx"] = max(-2.0, min(2.0, nav["vx"] + random.uniform(-0.05, 0.05)))
            nav["vy"] = max(-2.0, min(2.0, nav["vy"] + random.uniform(-0.05, 0.05)))
            nav["x"] += nav["vx"]
            nav["y"] += nav["vy"]
            if not (10 < nav["x"] < self.w - 10): nav["vx"] *= -1
            if not (10 < nav["y"] < self.h - 10): nav["vy"] *= -1
            try:
                self.coords(nav["cid"], nav["x"], nav["y"])
            except tk.TclError:
                pass

        self.tag_raise("nave")
        self.after(36, self._tick)


