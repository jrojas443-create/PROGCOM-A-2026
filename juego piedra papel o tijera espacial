                 C["accent"], ("Consolas", 15, "bold")).pack(pady=(0, 4))
        mk_label(overlay, "SPACE RPS  --  Edicion Clasica",
                 C["text2"], FUENTES["small"]).pack(pady=(0, 22))

        mk_btn(overlay, "NUEVA PARTIDA", C["accent2"], C["bg"],
