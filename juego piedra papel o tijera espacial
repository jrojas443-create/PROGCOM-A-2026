#  VENTANA DE JUEGO
# ══════════════════════════════════════════════════════════════
class VentanaJuego(tk.Frame):

    def __init__(self, master, modo: int, max_rondas: int,
                 jugadores: list, perfiles: dict):
        super().__init__(master, bg=PALETA["bg"])
        self.modo         = modo
        self.max_rondas   = max_rondas
        self.jugadores    = jugadores
        self.perfiles     = perfiles
        self.tema         = TEMAS[modo]
        self.puntos       = {j: 0 for j in jugadores}
        self.rondas       = 0
        self.elecciones   = {}
        self.turno_actual = 0
        self._bloqueado   = False
        self._cb_ronda    = None
        self.on_salir     = None
        self._build()

    # ── Construccion de la UI ────────────────────────────────
    def _build(self):
        t = self.tema
        C = PALETA

        # Encabezado
        hdr = tk.Frame(self, bg=C["panel"], pady=8)
        hdr.pack(fill="x")
        titulos = {1: "vs Maquina", 2: "2 Jugadores", 3: "3 Jugadores"}
        mk_label(hdr, f"o  SPACE RPS -- {titulos[self.modo]}  o",
                 t["accent"], FUENTES["bold"]).pack(side="left", padx=16)
        pf = tk.Frame(hdr, bg=C["panel"])
        pf.pack(side="left", expand=True)
        self._lbl_prog = mk_label(pf, self._txt_prog(), t["gold"], FUENTES["small"])
        self._lbl_prog.pack()
        self._cv_prog  = tk.Canvas(pf, width=260, height=6,
                                   bg=C["card"], highlightthickness=0)
        self._cv_prog.pack()
        self._barra = self._cv_prog.create_rectangle(
            0, 0, 0, 6, fill=t["accent"], outline="")
        mk_btn(hdr, "MENU", C["card"], t["accent"],
               self._salir, px=10, py=4).pack(side="right", padx=10)

        # Marcador
        self._fr_scores = tk.Frame(self, bg=C["bg"])
        self._fr_scores.pack(fill="x", padx=16, pady=(8, 4))
        self._dibujar_marcador()

        # Separador animado
        self._cv_sep = tk.Canvas(self, height=3, bg=C["bg"], highlightthickness=0)
        self._cv_sep.pack(fill="x", padx=16)
        self._sep_off = 0
        self._animar_sep()

        # Zona central
        zona = tk.Frame(self, bg=C["bg"])
        zona.pack(fill="x", padx=16, pady=6)

        self._vista_normal = tk.Frame(zona, bg=C["bg"])
        self._vista_normal.pack()
        self._lbl_emoji = mk_label(
            self._vista_normal, "?", t["muted"], ("Segoe UI Emoji", 42))
        self._lbl_emoji.pack()
        self._lbl_res = mk_label(
            self._vista_normal, "Selecciona tu arma!", t["text"], FUENTES["bold"])
        self._lbl_res.pack()

        self._vista_cd = tk.Frame(zona, bg=C["bg"])
        self._lbl_cd   = tk.Label(self._vista_cd, text="3",
                                  bg=C["bg"], fg=t["accent"],
                                  font=("Consolas", 72, "bold"))
        self._lbl_cd.pack(pady=4)

        self._vista_descanso = tk.Frame(zona, bg=C["bg"])
        mk_label(self._vista_descanso, "🚀", C["gold"],
                 ("Segoe UI Emoji", 40)).pack(pady=(4, 0))
        self._lbl_descanso = mk_label(
            self._vista_descanso, "Ronda siguiente",
            t["gold"], ("Consolas", 16, "bold"))
        self._lbl_descanso.pack(pady=4)
        mk_btn(self._vista_descanso, "LISTOS  >", t["accent2"], C["bg"],
               self._iniciar_ronda, px=20, py=8).pack(pady=4)

        # Turno (multiplayer)
        self._lbl_turno = mk_label(self, "", t["gold"], FUENTES["small"])
        if self.modo > 1:
            self._lbl_turno.pack(pady=2)
            self._dibujar_turno()

        # Botones de opciones
        btns_f = tk.Frame(self, bg=C["bg"])
        btns_f.pack(pady=6)
        self._btns = {}
        for op in OPCIONES:
            col = tk.Frame(btns_f, bg=C["bg"])
            col.pack(side="left", padx=6)
            em = mk_label(col, EMOJIS[op], t["text"], ("Segoe UI Emoji", 30))
            em.pack()
            b = tk.Button(col, text=op, width=8,
                          bg=C["card"], fg=t["text"],
                          font=("Consolas", 10), relief="flat", bd=0,
                          padx=5, pady=7, cursor="hand2",
                          activebackground=t["btn_h"], activeforeground=C["bg"],
                          command=lambda o=op: self._elegir(o))
            b.pack(pady=2)
            b.bind("<Enter>", lambda _, btn=b, lb=em: (
                btn.configure(bg=t["btn_h"]),
                lb.configure(font=("Segoe UI Emoji", 36))))
            b.bind("<Leave>", lambda _, btn=b, lb=em: (
                btn.configure(bg=C["card"]),
                lb.configure(font=("Segoe UI Emoji", 30))))
            em.bind("<Button-1>", lambda _, o=op: self._elegir(o))
            self._btns[op] = (b, em)

        # Reglas
        rf = tk.Frame(self, bg=C["panel"], padx=8, pady=4)
        rf.pack(fill="x", padx=20, pady=(2, 3))
        mk_label(rf, "REGLAS", t["gold"], ("Consolas", 8, "bold")).pack(anchor="w")
        mk_label(rf, "  |  ".join(REGLAS.values()),
                 C["text2"], ("Consolas", 6), wrap=880).pack(anchor="w")

        # Historial
        mk_label(self, "Historial", C["text2"], FUENTES["small"]).pack(
            anchor="w", padx=20)
        self._txt_log = tk.Text(
            self, height=3, bg=C["panel"], fg=t["text"],
            font=("Consolas", 8), relief="flat", bd=0,
            state="disabled", padx=6, pady=3)
        self._txt_log.pack(fill="x", padx=20, pady=(2, 4))

    # ── Animaciones ──────────────────────────────────────────
    def _animar_sep(self):
        self._sep_off = (self._sep_off + 5) % 1100
        x1 = self._sep_off - 200
        self._cv_sep.delete("all")
        self._cv_sep.create_rectangle(
            x1, 0, self._sep_off, 3, fill=self.tema["accent"], outline="")
        self.after(16, self._animar_sep)

    def _cuenta_regresiva(self, callback):
        self._bloqueado = True
        t     = self.tema
        pasos = [("3", PALETA["teal"], 800),
                 ("2", PALETA["gold"], 800),
                 ("1", t["accent"],    800),
                 ("YA!", t["win"],     600)]

        def paso(i=0):
            if i < len(pasos):
                txt, col, delay = pasos[i]
                fs = 72 if txt != "YA!" else 34
                self._lbl_cd.configure(text=txt, fg=col,
                                       font=("Consolas", fs, "bold"))
                self._vista_normal.pack_forget()
                self._vista_cd.pack()
                self.after(delay, lambda: paso(i + 1))
            else:
                self._vista_cd.pack_forget()
                self._vista_normal.pack()
                self._bloqueado = False
                callback()
        paso()

    def _animar_resultado(self, color, paso=0):
        if paso >= 6:
            self._lbl_res.configure(fg=color)
            return
        c = color if paso % 2 == 0 else self.tema["text"]
        self._lbl_res.configure(fg=c)
        self.after(90, lambda: self._animar_resultado(color, paso + 1))

    def _slot_emoji(self, seq, i=0):
        if i < len(seq):
            self._lbl_emoji.configure(text=seq[i])
            self.after(65, lambda: self._slot_emoji(seq, i + 1))

    def _pulso_btn(self, op: str):
        if op not in self._btns:
            return
        btn, _ = self._btns[op]
        cols   = [self.tema["win"], PALETA["card"]] * 4
        def paso(i=0):
            if i < len(cols):
                btn.configure(bg=cols[i])
                self.after(75, lambda: paso(i + 1))
        paso()

    # ── Gestion de vistas de ronda ───────────────────────────
    def _mostrar_descanso(self, callback):
        self._cb_ronda  = callback
        self._bloqueado = True
        self._vista_normal.pack_forget()
        self._vista_cd.pack_forget()
        sig = self.rondas + 1
        self._lbl_descanso.configure(
            text=f"Ronda {sig} de {self.max_rondas}  --  listos?")
        self._vista_descanso.pack()

    def _iniciar_ronda(self):
        self._vista_descanso.pack_forget()
        self._vista_normal.pack()
        cb, self._cb_ronda = self._cb_ronda, None
        self._cuenta_regresiva(cb)

    # ── Actualizacion de widgets ─────────────────────────────
    def _dibujar_marcador(self):
        for w in self._fr_scores.winfo_children():
            w.destroy()
        t = self.tema
        C = PALETA
        for j in self.jugadores:
            av   = self.perfiles.get(j, {}).get("avatar", "🚀")
            card = tk.Frame(self._fr_scores, bg=C["card"], padx=12, pady=6)
            card.pack(side="left", expand=True, fill="x", padx=4)
            mk_label(card, av, t["text"], ("Segoe UI Emoji", 16)).pack()
            mk_label(card, j, t["muted"], FUENTES["small"]).pack()
            mk_label(card, str(self.puntos[j]), t["win"],
                     ("Consolas", 26, "bold")).pack()

    def _dibujar_turno(self):
        j  = self.jugadores[self.turno_actual]
        av = self.perfiles.get(j, {}).get("avatar", "🚀")
        self._lbl_turno.configure(text=f"{av}  Turno de {j}  -- elige en secreto")

    def _actualizar_barra(self):
        pct = min(self.rondas / self.max_rondas, 1.0)
        self._cv_prog.coords(self._barra, 0, 0, int(260 * pct), 6)
        self._lbl_prog.configure(text=self._txt_prog())

    def _txt_prog(self) -> str:
        return f"Ronda {self.rondas} / {self.max_rondas}"

    def _log(self, texto: str):
        self._txt_log.configure(state="normal")
        self._txt_log.insert("end", texto + "\n")
        self._txt_log.see("end")
        self._txt_log.configure(state="disabled")

    # ── Logica principal ─────────────────────────────────────
    def _elegir(self, opcion: str):
        if self._bloqueado:
            return
        if self.modo == 1:
            self._bloqueado = True
            cb = lambda: self._vs_maquina(opcion)
            if self.rondas == 0:
                self._cuenta_regresiva(cb)
            else:
                self._mostrar_descanso(cb)
        else:
            j = self.jugadores[self.turno_actual]
            self.elecciones[j] = opcion
            self._lbl_res.configure(
                text=f"{j} eligio en secreto.", fg=self.tema["gold"])
            self._lbl_emoji.configure(text="?")
            self.turno_actual += 1
            if self.turno_actual < len(self.jugadores):
                self._dibujar_turno()
            else:
                self._bloqueado = True
                cb = self._resolver_multi
                if self.rondas == 0:
                    self.after(200, lambda: self._cuenta_regresiva(cb))
                else:
                    self.after(200, lambda: self._mostrar_descanso(cb))

    def _vs_maquina(self, eleccion: str):
        self._bloqueado = True
        maquina         = random.choice(OPCIONES)
        self.rondas    += 1
        res, razon      = resolver(eleccion, maquina)
        j1              = self.jugadores[0]

        seq = [EMOJIS[random.choice(OPCIONES)] for _ in range(10)]
        seq.append(f"{EMOJIS[eleccion]} vs {EMOJIS[maquina]}")
        self._slot_emoji(seq)

        def mostrar():
            if res == "a":
                color, msg = self.tema["win"], f"Ganaste!  {razon}"
                self.puntos[j1] += 1
                actualizar_stats(self.perfiles, j1, gano=True)
                self._pulso_btn(eleccion)
            elif res == "b":
                color, msg = self.tema["lose"], f"Perdiste.  {razon}"
                self.puntos["Maquina"] = self.puntos.get("Maquina", 0) + 1
                actualizar_stats(self.perfiles, j1, gano=False)
            else:
                color, msg = self.tema["tie"], f"Empate.  Ambos: {eleccion}"
                actualizar_stats(self.perfiles, j1, gano=False)

            self._lbl_emoji.configure(
                text=f"{EMOJIS[eleccion]}  vs  {EMOJIS[maquina]}")
            self._lbl_res.configure(text=msg)
            self._animar_resultado(color)
            self._log(f"R{self.rondas}: Tu={eleccion} Maq={maquina} --> {msg}")
            self._dibujar_marcador()
            self._actualizar_barra()
            self._bloqueado = False
            if self.rondas >= self.max_rondas:
                self.after(900, self._fin)

        self.after(len(seq) * 65 + 120, mostrar)

    def _resolver_multi(self):
        self.rondas += 1
        js      = self.jugadores
        elec    = self.elecciones
        resumen = "  |  ".join(f"{j}:{EMOJIS[elec[j]]}" for j in js)

        if self.modo == 2:
            j1, j2 = js[0], js[1]
            res, razon = resolver(elec[j1], elec[j2])
            if res == "a":
                ganadores = [j1]; self.puntos[j1] += 1
            elif res == "b":
                ganadores = [j2]; self.puntos[j2] += 1
            else:
                ganadores = []; razon = "Empate"
        else:
            pts, razones = {j: 0 for j in js}, []
            for i, ja in enumerate(js):
                for jb in js[i + 1:]:
                    r, rz = resolver(elec[ja], elec[jb])
                    razones.append(rz)
                    if r == "a":   pts[ja] += 1
                    elif r == "b": pts[jb] += 1
            mp        = max(pts.values())
            ganadores = [j for j, p in pts.items() if p == mp]
            if len(ganadores) == len(js): ganadores = []
            razon = " | ".join(dict.fromkeys(razones))
            for j in ganadores: self.puntos[j] += 1

        seq = [EMOJIS[random.choice(OPCIONES)] for _ in range(10)] + ["!"]
        self._slot_emoji(seq)

        def mostrar():
            if ganadores:
                color = self.tema["win"]
                txt   = f"Gana: {', '.join(ganadores)}!  {razon}"
                for j in ganadores:
                    actualizar_stats(self.perfiles, j, gano=True)
            else:
                color = self.tema["tie"]
                txt   = f"Empate!  {razon}"

            self._lbl_emoji.configure(text="!")
            self._lbl_res.configure(text=f"{resumen}\n{txt}", fg=color)
            self._animar_resultado(color)
            self._log(f"R{self.rondas}: {resumen} --> {txt}")
            self._dibujar_marcador()
            self._actualizar_barra()
            self.elecciones   = {}
            self.turno_actual = 0
            self._dibujar_turno()
            self._bloqueado = False
            if self.rondas >= self.max_rondas:
                self.after(900, self._fin)

        self.after(len(seq) * 65 + 120, mostrar)

    def _fin(self):
        C  = PALETA
        t  = self.tema
        mp = max(self.puntos.values())
        campeones = [j for j, p in self.puntos.items() if p == mp]

        v = tk.Toplevel(self)
        v.title("FIN DEL JUEGO")
        v.configure(bg=C["bg"])
        v.resizable(False, False)
        v.grab_set()
        v.geometry("440x360")
        v.update_idletasks()
        x = (v.winfo_screenwidth()  - 440) // 2
        y = (v.winfo_screenheight() - 360) // 2
        v.geometry(f"440x360+{x}+{y}")

        mk_label(v, "o  FIN DEL JUEGO  o",
                 t["gold"], ("Consolas", 16, "bold")).pack(pady=(22, 8))

        if len(campeones) == 1:
            av  = self.perfiles.get(campeones[0], {}).get("avatar", "🏆")
            msg = f"{av}  {campeones[0]} gana!"
            col = t["win"]
        else:
            msg = f"Empate: {', '.join(campeones)}"
            col = t["tie"]
        mk_label(v, msg, col, ("Consolas", 14, "bold")).pack(pady=4)

        medallas = ["1ro", "2do", "3ro"]
        for i, (j, p) in enumerate(sorted(self.puntos.items(), key=lambda x: -x[1])):
            fila = tk.Frame(v, bg=C["card"], padx=16, pady=5)
            fila.pack(fill="x", padx=30, pady=3)
            av     = self.perfiles.get(j, {}).get("avatar", "🚀")
            medalla = medallas[i] if i < len(medallas) else " "
            mk_label(fila, f"{medalla}  {av}  {j}",
                     C["text"], FUENTES["normal"]).pack(side="left")
            mk_label(fila, f"{p} pts", t["win"],
                     ("Consolas", 13, "bold")).pack(side="right")

        bf = tk.Frame(v, bg=C["bg"])
        bf.pack(pady=16)
        mk_btn(bf, "Otra vez", t["accent2"], C["bg"],
               lambda: [v.destroy(), self._reiniciar()],
               px=14, py=8).pack(side="left", padx=8)
        mk_btn(bf, "Menu", C["card"], C["text2"],
               lambda: [v.destroy(), self._salir()],
               px=14, py=8).pack(side="left", padx=8)

    def _reiniciar(self):
        self.puntos       = {j: 0 for j in self.jugadores}
        self.rondas       = 0
        self.elecciones   = {}
        self.turno_actual = 0
        self._bloqueado   = False
        self._lbl_emoji.configure(text="?", fg=self.tema["muted"])
        self._lbl_res.configure(text="Selecciona tu arma!", fg=self.tema["text"])
        self._txt_log.configure(state="normal")
        self._txt_log.delete("1.0", "end")
        self._txt_log.configure(state="disabled")
        self._dibujar_marcador()
        self._actualizar_barra()
        if self.modo > 1:
            self._dibujar_turno()

    def _salir(self):
        if self.on_salir:
            self.on_salir()


