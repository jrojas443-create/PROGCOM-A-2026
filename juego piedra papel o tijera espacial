# ══════════════════════════════════════════════════════════════
#  APLICACION PRINCIPAL
# ══════════════════════════════════════════════════════════════
class App(tk.Tk):
    W, H = 900, 640

    def __init__(self):
        super().__init__()
        self.title("SPACE RPS -- Piedra . Papel . Tijera . Lagarto . Spock")
        self.configure(bg=PALETA["bg"])
        self.resizable(False, False)
        self._centrar()
        self._perfil_activo = None
        self._perfiles      = cargar_perfiles()
        self._frame         = None
        self._ir_login()

    def _centrar(self):
        self.geometry(f"{self.W}x{self.H}")
        self.update_idletasks()
        x = (self.winfo_screenwidth()  - self.W) // 2
        y = (self.winfo_screenheight() - self.H) // 2
        self.geometry(f"{self.W}x{self.H}+{x}+{y}")

    def _cambiar_frame(self, nuevo: tk.Frame):
        if self._frame:
            self._frame.destroy()
        self._frame = nuevo
        nuevo.place(x=0, y=0, width=self.W, height=self.H)

    def _ir_login(self):
        self._cambiar_frame(PantallaLogin(self, self._post_login))

    def _post_login(self, nombre: str, datos: dict):
        self._perfil_activo = datos
        self._perfiles      = cargar_perfiles()
        self._ir_menu(nombre, datos)

    def _ir_menu(self, nombre: str, datos: dict):
        self._cambiar_frame(MenuPrincipal(
            self, nombre, datos,
            on_nueva_partida=lambda: self._configurar_partida(nombre, datos),
            on_cambiar_perfil=self._ir_login,
        ))

    def _configurar_partida(self, nombre: str, datos: dict):
        self._perfiles = cargar_perfiles()
        dlg = DialogoPartida(self, datos, self._perfiles)
        self.wait_window(dlg)
        if dlg.resultado is None:
            return
        modo, rondas, jugadores = dlg.resultado
        self._iniciar_juego(modo, rondas, jugadores, nombre)

    def _iniciar_juego(self, modo: int, rondas: int,
                       jugadores: list, perfil_principal: str):
        self._perfiles = cargar_perfiles()
        juego = VentanaJuego(self, modo, rondas, jugadores, self._perfiles)
        self._cambiar_frame(juego)
        juego.on_salir = lambda: self._post_juego(perfil_principal)

    def _post_juego(self, nombre: str):
        self._perfiles = cargar_perfiles()
        datos = self._perfiles.get(nombre, self._perfil_activo)
        self._ir_menu(nombre, datos)


# ══════════════════════════════════════════════════════════════
if __name__ == "__main__":
    App().mainloop()
