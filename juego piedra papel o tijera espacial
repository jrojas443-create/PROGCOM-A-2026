class DialogoPartida(tk.Toplevel):

    def __init__(self, master, perfil_activo: dict, perfiles: dict):
        super().__init__(master)
        self.resultado = None   # (modo, rondas, [jugadores])
        self.perfil    = perfil_activo
        self.perfiles  = perfiles
        self.configure(bg=PALETA["bg"])
        self.resizable(False, False)
        self.title("Configurar Partida")
        self.grab_set()
        self._centrar(460, 400)
        self._build()

    def _centrar(self, w: int, h: int):
        self.geometry(f"{w}x{h}")
        self.update_idletasks()
        x = (self.winfo_screenwidth()  - w) // 2
        y = (self.winfo_screenheight() - h) // 2
        self.geometry(f"{w}x{h}+{x}+{y}")

    def _build(self):
        C  = PALETA
        av = self.perfil.get("avatar", "🚀")
        nm = self.perfil.get("nombre", "?")
        mk_label(self, f"{av}  Hola, {nm}!",
                 C["gold"], FUENTES["bold"]).pack(pady=(20, 4))
        mk_label(self, "Configura tu partida",
                 C["text2"], FUENTES["small"]).pack(pady=(0, 12))

        # Modo
        mf = tk.Frame(self, bg=C["bg"])
        mf.pack(pady=4)
        mk_label(mf, "Modo de juego:", C["text2"], FUENTES["small"]).pack(anchor="w")
        self._modo_var = tk.IntVar(value=1)
        for txt, val in [("vs Maquina  (solo tu)", 1),
                         ("2 Jugadores",            2),
                         ("3 Jugadores",            3)]:
            tk.Radiobutton(mf, text=txt, variable=self._modo_var, value=val,
                           bg=C["bg"], fg=C["text"], selectcolor=C["card2"],
                           activebackground=C["bg"], font=FUENTES["normal"],
                           cursor="hand2").pack(anchor="w", pady=2)

        mk_sep(self, C["accent"]).pack(fill="x", padx=20, pady=10)

        # Rondas
        rf = tk.Frame(self, bg=C["bg"])
        rf.pack(pady=4)
        mk_label(rf, "Numero de rondas:",
                 C["text2"], FUENTES["small"]).pack(anchor="w")
        rb_f = tk.Frame(rf, bg=C["bg"])
        rb_f.pack(pady=4)
        self._rondas_var = tk.IntVar(value=5)
        for n in [3, 5, 7, 10]:
            rb = tk.Radiobutton(rb_f, text=str(n),
                                variable=self._rondas_var, value=n,
                                bg=C["card"], fg=C["text"],
                                selectcolor=C["accent2"],
                                activebackground=C["card"],
                                font=("Consolas", 15, "bold"),
                                indicatoron=False, relief="flat", bd=0,
                                padx=16, pady=8, cursor="hand2", width=3)
            rb.pack(side="left", padx=4)
            rb.bind("<Enter>", lambda _, b=rb: b.configure(bg=C["btn_h"]))
            rb.bind("<Leave>", lambda _, b=rb: b.configure(bg=C["card"]))

        cf = tk.Frame(rf, bg=C["bg"])
        cf.pack(pady=6)
        mk_label(cf, "Personalizado:", C["text2"], FUENTES["small"]).pack(
            side="left", padx=(0, 6))
        self._e_custom = tk.Entry(
            cf, width=5, bg=C["card"], fg=C["text"],
            insertbackground=C["accent"], relief="flat",
            font=FUENTES["normal"], justify="center")
        self._e_custom.pack(side="left")
        self._e_custom.bind("<KeyRelease>", self._sync_custom)

        mk_sep(self, C["accent"]).pack(fill="x", padx=20, pady=8)
        mk_btn(self, "SIGUIENTE  >", C["accent2"], C["bg"],
               self._confirmar, px=28, py=10).pack(pady=4)

    def _sync_custom(self, _):
        txt = self._e_custom.get().strip()
        if txt.isdigit() and int(txt) > 0:
            self._rondas_var.set(int(txt))

    def _confirmar(self):
        modo   = self._modo_var.get()
        rondas = max(1, self._rondas_var.get())
        nombre_j1 = self.perfil.get("nombre", "Jugador 1")
        nombres   = [nombre_j1]

        for i in range(modo - 1):
            dlg = DialogoPerfil(self, i + 2, self.perfiles)
            self.wait_window(dlg)
            if dlg.resultado is None:
                return
            self.perfiles = cargar_perfiles()
            nombres.append(dlg.resultado)

        self.resultado = (modo, rondas, nombres)
        self.destroy()


