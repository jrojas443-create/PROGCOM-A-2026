def resolver(a: str, b: str) -> tuple:
    """Devuelve ('a'|'b'|'empate', razon)."""
    if a == b:
        return "empate", "Empate"
    if b in VENCE[a]:
        return "a", REGLAS.get((a, b), f"{a} vence a {b}")
    return "b", REGLAS.get((b, a), f"{b} vence a {a}")


# ══════════════════════════════════════════════════════════════
#  GESTION DE PERFILES
# ══════════════════════════════════════════════════════════════
def cargar_perfiles() -> dict:
    try:
        with open(PERFILES_FILE, "r", encoding="utf-8") as f:
            return json.load(f)
    except (FileNotFoundError, json.JSONDecodeError):
        return {}


def guardar_perfiles(data: dict) -> None:
    try:
        with open(PERFILES_FILE, "w", encoding="utf-8") as f:
            json.dump(data, f, ensure_ascii=False, indent=2)
    except OSError:
        pass


def actualizar_stats(perfiles: dict, nombre: str, gano: bool) -> None:
    if nombre not in perfiles:
        return
    p = perfiles[nombre]
    p["games"] = p.get("games", 0) + 1
    if gano:
        p["wins"] = p.get("wins", 0) + 1
    guardar_perfiles(perfiles)


def win_rate(wins: int, games: int) -> str:
    return f"{int(wins / games * 100)}%" if games else "0%"


