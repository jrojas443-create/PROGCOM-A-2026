#  MENU PRINCIPAL
# ══════════════════════════════════════════════════════════════
class MenuPrincipal(tk.Frame):

    def __init__(self, master, nombre: str, datos: dict,
                 on_nueva_partida, on_cambiar_perfil):
        super().__init__(master, bg=PALETA["bg"])
        C = PALETA
        FondoEstelar(self, master.W, master.H).place(x=0, y=0)

        overlay = tk.Frame(self, bg=C["bg"])
        overlay.place(relx=0.5, rely=0.5, anchor="center")

        wins  = datos.get("wins", 0)
        games = datos.get("games", 0)

        mk_label(overlay, datos.get("avatar", "🚀"), C["text"],
                 ("Segoe UI Emoji", 50)).pack(pady=(0, 4))
        mk_label(overlay, nombre.upper(), C["gold"], FUENTES["large"]).pack()
        mk_label(overlay,
                 f"{datos.get('edad','?')} anos . {datos.get('genero','-')}",
                 C["text2"], FUENTES["small"]).pack(pady=(2, 2))
        mk_label(overlay,
                 f"Partidas: {games}  |  Victorias: {wins}  |  Win rate: {win_rate(wins, games)}",
