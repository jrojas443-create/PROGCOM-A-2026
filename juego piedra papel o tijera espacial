#  DIALOGO: PERFIL RAPIDO (jugadores adicionales)
# ══════════════════════════════════════════════════════════════
class DialogoPerfil(tk.Toplevel):

    def __init__(self, master, num_jugador: int, perfiles: dict):
        super().__init__(master)
        self.resultado = None
        self.perfiles  = perfiles
        self.configure(bg=PALETA["bg"])
        self.resizable(False, False)
        self.title(f"Jugador {num_jugador}")
        self.grab_set()
        self._centrar(480, 540)
        self._build(num_jugador)

    def _centrar(self, w: int, h: int):
        self.geometry(f"{w}x{h}")
        self.update_idletasks()
        x = (self.winfo_screenwidth()  - w) // 2
        y = (self.winfo_screenheight() - h) // 2
        self.geometry(f"{w}x{h}+{x}+{y}")

    def _build(self, num: int):
        C = PALETA
        mk_label(self, f"o  JUGADOR {num}  o",
                 C["accent"], FUENTES["titulo"]).pack(pady=(16, 4))
        mk_label(self, "Selecciona o crea un perfil",
                 C["text2"], FUENTES["small"]).pack(pady=(0, 10))

        if self.perfiles:
            mk_label(self, "Perfiles disponibles:",
                     C["gold"], FUENTES["small"]).pack(anchor="w", padx=22)
            for nombre, datos in self.perfiles.items():
                card = tk.Frame(self, bg=C["card"], padx=10, pady=6, cursor="hand2")
                card.pack(fill="x", padx=22, pady=2)
                tk.Frame(card, bg=C["accent"], width=3).pack(
                    side="left", fill="y", padx=(0, 8))
                info = tk.Frame(card, bg=C["card"])
                info.pack(side="left", expand=True)
                mk_label(info,
                         f"{datos.get('avatar','🚀')}  {nombre}",
                         C["gold"], FUENTES["bold"]).pack(anchor="w")
                mk_label(info,
                         f"{datos.get('edad','?')} anos . {datos.get('genero','-')}  |  "
                         f"Partidas: {datos.get('games',0)}  Wins: {datos.get('wins',0)}",
                         C["text2"], FUENTES["small"]).pack(anchor="w")
                mk_btn(card, "ELEGIR", C["accent2"], C["bg"],
                       lambda n=nombre: self._elegir(n), px=10, py=4).pack(
                    side="right", padx=4)

        mk_sep(self, C["accent"]).pack(fill="x", padx=20, pady=8)
        mk_label(self, "O crea uno nuevo:",
                 C["gold"], FUENTES["small"]).pack(anchor="w", padx=22)

        self._form = FormPerfil(self)
        self._form.pack(padx=22, pady=4, fill="x")

        mk_sep(self, C["accent"]).pack(fill="x", padx=20, pady=8)
        mk_btn(self, "CREAR Y CONTINUAR", C["accent2"], C["bg"],
               self._crear, px=20, py=8).pack(pady=(0, 12))

    def _elegir(self, nombre: str):
        self.resultado = nombre
        self.destroy()

    def _crear(self):
        datos = self._form.obtener()
        if datos is None:
            return
        if datos["nombre"] in self.perfiles:
            messagebox.showerror("Error", f"Ya existe '{datos['nombre']}'.")
            return
        datos["wins"] = datos["games"] = 0
        self.perfiles[datos["nombre"]] = datos
        guardar_perfiles(self.perfiles)
        self.resultado = datos["nombre"]
        self.destroy()


